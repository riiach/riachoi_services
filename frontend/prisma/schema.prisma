// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Subscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  status    String   @default("ACTIVE")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("subscribers")
}

model Feature {
  id          String   @id @default(cuid())
  name        String    @unique
  koreanName    String
  description String?
  koreanDescription String?

  minPriceDollar       Int?
  maxPriceDollar       Int?

  minPriceWon       Int?
  maxPriceWon       Int?

  isActive    Boolean  @default(true)
  isPopular   Boolean  @default(false)

  categories  Category[]
  packages    Package[]

  estimatedHours    Int?
  minEstimatedDays  Int?
  maxEstimatedDays Int?
  estimatedMonths   Int?

  icon  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  estimateItems EstimateItem[]

  @@map("features")
}

model Category {
  id          String   @id @default(cuid())
  name        String    @unique
  koreanName  String?
  description String?
  koreanDescription String?
  tag   String?
  koreanTag String?

  features    Feature[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("categories")
}

model   Package {
    id  String  @id @default(cuid())

    name    String
    koreanName  String

    description String?
    koreanDescription   String?

    minPriceDollar  Int?
    maxPriceDollar  Int?

    minPriceWon Int?
    maxPriceWon Int?

    features    Feature[]

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt

    @@map("packages")
}

model EstimateRequest {
  id         String   @id @default(cuid())
  name       String
  email      String
  message    String?
  totalPrice Int
  status     String   @default("PENDING")

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items EstimateItem[]

  @@map("estimate_requests")
}

model EstimateItem {
  id                String @id @default(cuid())

  estimateRequestId String
  featureId         String

  featureName       String
  price             Int
  quantity          Int
  subtotal          Int

  estimateRequest   EstimateRequest @relation(fields: [estimateRequestId], references: [id])
  feature           Feature         @relation(fields: [featureId], references: [id])

  @@map("estimate_items")
}

model EmailLog {
  id             String   @id @default(cuid())

  recipientEmail String
  type           String
  subject        String
  status         String

  resendEmailId  String?

  sentAt         DateTime?
  createdAt      DateTime @default(now())

  @@map("email_logs")
}
